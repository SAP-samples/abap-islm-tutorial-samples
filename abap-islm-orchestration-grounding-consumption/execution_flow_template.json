{
    "modules": {
        "prompt_templating": {
            "prompt": {
                "template": [
                    {
                        "role": "user",
                        "content": [
                            {
                                "type": "text",
                                "text": "."
                            }
                        ]
                    }
                ],
                "defaults": {}
            },
            "model": {
                "name": "anthropic--claude-4-sonnet",
                "params": {
